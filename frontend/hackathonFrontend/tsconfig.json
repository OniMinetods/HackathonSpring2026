{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@app/*": ["./src/app/*"],
            "@screens/*": ["./src/screens/*"],
            "@services/*": ["./src/services/*"],
            "@components/*": ["./src/components/*"],
            "@utils/*": ["./src/utils/*"],
            "@hooks/*": ["./src/hooks/*"],
            "@constants/*": ["./src/shared/constants/*"],
            "@types/*": ["./src/types/*"],
            "@store/*": ["./src/store/*"],
            "@icons/*": ["./src/shared/ui/icons/*"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules"]
}
